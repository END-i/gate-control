{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total HTTP Requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(anpr_http_requests_total)",
          "legendFormat": "Total requests",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(anpr_http_requests_total[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate (5xx, req/s)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] }, "color": { "mode": "thresholds" } } },
      "targets": [
        {
          "expr": "sum(rate(anpr_http_requests_total{status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P99 Latency (s)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(anpr_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Rate by Status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(anpr_http_requests_total[1m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Duration Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(anpr_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(anpr_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(anpr_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Rate by Path",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(anpr_http_requests_total[1m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["anpr"],
  "title": "ANPR Backend",
  "uid": "anpr-backend-overview",
  "version": 1
}
