# Global
# For local backend + local/Docker Postgres use localhost host.
# For full Docker Compose stack use postgres host.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/anpr
SECRET_KEY=password
FRONTEND_URL=http://localhost:3000
APP_ENV=development
# Empty by default: create_all enabled only in dev/local/test.
# Set AUTO_CREATE_SCHEMA=1 to force, AUTO_CREATE_SCHEMA=0 to disable.
AUTO_CREATE_SCHEMA=

# Admin seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
ADMIN_ROLE=admin

# Relay
RELAY_IP=http://camera-relay.local/trigger
RELAY_USERNAME=admin
RELAY_PASSWORD=password

# Webhook auth mode: token | hmac
WEBHOOK_AUTH_MODE=token
WEBHOOK_SHARED_SECRET=password
WEBHOOK_HMAC_SECRET=password
WEBHOOK_MAX_SKEW_SECONDS=300
WEBHOOK_MAX_IMAGE_BYTES=5242880

# Backend runtime
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
AUTH_LOGIN_RATE_LIMIT=20
AUTH_LOGIN_RATE_WINDOW_SECONDS=60
WEBHOOK_RATE_LIMIT=120
WEBHOOK_RATE_WINDOW_SECONDS=60
SENSITIVE_RATE_LIMIT=60
SENSITIVE_RATE_WINDOW_SECONDS=60
RELAY_WORKER_POLL_SECONDS=1
RELAY_WORKER_RETRY_SECONDS=5
RELAY_WORKER_MAX_ATTEMPTS=3
BACKEND_COVERAGE_MIN=70

# Frontend
VITE_API_BASE_URL=http://localhost:8010/api

# Optional host port bindings for docker-compose
POSTGRES_PORT=5432
BACKEND_PORT=8010
FRONTEND_PORT=3000
