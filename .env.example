# Global
# For local backend + local/Docker Postgres use localhost host.
# For full Docker Compose stack use postgres host.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/anpr
SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:3000
APP_ENV=development
# Empty by default: create_all enabled only in dev/local/test.
# Set AUTO_CREATE_SCHEMA=1 to force, AUTO_CREATE_SCHEMA=0 to disable.
AUTO_CREATE_SCHEMA=

# Admin seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
ADMIN_ROLE=admin

# Relay
RELAY_IP=http://camera-relay.local/trigger
RELAY_USERNAME=admin
RELAY_PASSWORD=change-me-in-production

# Webhook auth mode: token | hmac
WEBHOOK_AUTH_MODE=token
WEBHOOK_SHARED_SECRET=change-me-in-production
WEBHOOK_HMAC_SECRET=change-me-in-production
WEBHOOK_MAX_SKEW_SECONDS=300
WEBHOOK_MAX_IMAGE_BYTES=5242880

# Backend runtime
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
AUTH_LOGIN_RATE_LIMIT=20
AUTH_LOGIN_RATE_WINDOW_SECONDS=60
WEBHOOK_RATE_LIMIT=120
WEBHOOK_RATE_WINDOW_SECONDS=60
SENSITIVE_RATE_LIMIT=60
SENSITIVE_RATE_WINDOW_SECONDS=60
RELAY_WORKER_POLL_SECONDS=1
RELAY_WORKER_RETRY_SECONDS=5
RELAY_WORKER_MAX_ATTEMPTS=3

# Frontend
VITE_API_BASE_URL=http://localhost:8010/api

# Optional host port bindings for docker-compose
POSTGRES_PORT=5432
BACKEND_PORT=8010
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# Optional: Redis (used for distributed rate limiting when set)
# REDIS_URL=redis://localhost:6379/0

# Optional: Prometheus metrics endpoint protection
# METRICS_API_KEY=change-me-in-production

# Optional: trusted reverse-proxy IPs for real client IP extraction (comma-separated)
# TRUSTED_PROXY_IPS=127.0.0.1,10.0.0.1

# Optional: skip startup tasks in tests/CI (relay worker, seed, schema create)
# ANPR_SKIP_STARTUP_TASKS=1

# ---------------------------------------------------------------------------
# Media storage (default: local filesystem under backend/media/)
MEDIA_STORAGE_BACKEND=local
MEDIA_RETENTION_HOT_DAYS=30

# Optional: S3/MinIO storage (set MEDIA_STORAGE_BACKEND=s3 to activate)
# S3_BUCKET=anpr-media
# S3_ENDPOINT_URL=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# S3_PUBLIC_BASE_URL=http://localhost:9000/anpr-media

# ---------------------------------------------------------------------------
# Optional: HashiCorp Vault for secrets injection (leave empty to skip)
# VAULT_ADDR=http://vault.local:8200
# VAULT_TOKEN=
# VAULT_SECRET_PATH=secret/data/anpr
