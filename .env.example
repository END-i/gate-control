# Global
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/anpr
SECRET_KEY=change-me
FRONTEND_URL=http://localhost:3000

# Admin seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Relay
RELAY_IP=http://camera-relay.local/trigger
RELAY_USERNAME=admin
RELAY_PASSWORD=change-me

# Webhook auth mode: token | hmac
WEBHOOK_AUTH_MODE=token
WEBHOOK_SHARED_SECRET=change-me
WEBHOOK_HMAC_SECRET=change-me
WEBHOOK_MAX_SKEW_SECONDS=300

# Backend runtime
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api

# Optional host port bindings for docker-compose
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000
